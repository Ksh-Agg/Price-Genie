    "# Derived numeric features\n",
    "df['discount_pct'] = (df['discount'] / df['initial_price']) * 100   #percentage discount\n",
    "df['price_diff'] = df['initial_price'] - df['final_price']          #absolute price difference\n",
    "df['rating_per_price'] = df['rating'] / (df['final_price'] + 1)     #value-for-money metric\n",
    "\n",
    "# Text length features\n",
    "df['title_len'] = df['title'].astype(str).apply(len)                \n",
    "df['desc_len'] = df['product_description'].astype(str).apply(len)   \n",
    "\n",
    "# Rating category\n",
    "df['rating_category'] = pd.cut(df['rating'], bins=[0, 2, 3.5, 5], labels=['low', 'medium', 'high'])     #Converts numerical ratings into ordinal categories"
